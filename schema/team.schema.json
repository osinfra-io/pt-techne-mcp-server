{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osinfra.io/schemas/team.schema.json",
  "title": "Team",
  "description": "A pt-logos team specification. The schema is the single source of truth for team configuration; the renderer produces tfvars matching this shape exactly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "team_key",
    "datadog_team_memberships",
    "display_name",
    "github_parent_team_memberships",
    "google_basic_groups_memberships",
    "team_type"
  ],
  "properties": {
    "team_key": {
      "description": "Team key. Must match the team_type prefix scheme: pt- (platform), st- (stream-aligned), ct- (complicated-subsystem), et- (enabling).",
      "type": "string",
      "pattern": "^(pt|st|ct|et)-[a-z][a-z0-9-]*[a-z0-9]$"
    },
    "datadog_team_memberships": {
      "description": "Datadog team memberships. admins manage the team; members have read-only access.",
      "type": "object",
      "additionalProperties": false,
      "required": ["admins", "members"],
      "properties": {
        "admins": { "$ref": "#/$defs/emailList" },
        "members": { "$ref": "#/$defs/emailList" }
      }
    },
    "display_name": {
      "description": "Team display name. Title Case; spaces and the lowercase word \"and\" are allowed.",
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]*( (and|[A-Z][A-Za-z]*))*$"
    },
    "display_name_comment": {
      "description": "Optional inline comment rendered after display_name. Used for the team etymology blurb.",
      "type": "string"
    },
    "enable_google_project": {
      "description": "Enable a Google Cloud project for this team.",
      "type": "boolean"
    },
    "enable_opentofu_state_management": {
      "description": "Enable OpenTofu state management. Requires enable_workflows = true.",
      "type": "boolean"
    },
    "enable_workflows": {
      "description": "Enable GitHub Actions service account, workload identity federation, and group memberships.",
      "type": "boolean"
    },
    "github_child_teams_memberships": {
      "description": "GitHub child team memberships. The four standard teams (sandbox-approvers, non-production-approvers, production-approvers, repository-administrators) are always created; this block sets memberships and may add custom child teams.",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/githubMembership" }
    },
    "github_parent_team_memberships": {
      "description": "GitHub parent team memberships. All team members should be listed here. Use GitHub usernames (NOT email addresses).",
      "$ref": "#/$defs/githubMembership"
    },
    "github_repositories": {
      "description": "GitHub repositories owned by this team.",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/githubRepository" }
    },
    "google_basic_groups_memberships": {
      "description": "Google Cloud Identity basic groups: admin, reader, writer.",
      "type": "object",
      "additionalProperties": false,
      "required": ["admin", "reader", "writer"],
      "properties": {
        "admin": { "$ref": "#/$defs/googleGroup" },
        "reader": { "$ref": "#/$defs/googleGroup" },
        "writer": { "$ref": "#/$defs/googleGroup" }
      }
    },
    "google_browser_groups_memberships": {
      "description": "pt-corpus only. Per-environment console browse access for pt-corpus service accounts.",
      "$ref": "#/$defs/envScopedGoogleGroups"
    },
    "google_project_creator_groups_memberships": {
      "description": "pt-corpus only. Per-environment project creator access for pt-corpus service accounts.",
      "$ref": "#/$defs/envScopedGoogleGroups"
    },
    "google_project_enable_datadog": {
      "description": "Enable Datadog Google Cloud integration for the team project.",
      "type": "boolean"
    },
    "google_project_services": {
      "description": "Additional GCP API services to enable in the team project.",
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+\\.googleapis\\.com$" }
    },
    "google_xpn_admin_groups_memberships": {
      "description": "pt-corpus only. Per-environment shared VPC (XPN) admin access for pt-corpus service accounts.",
      "$ref": "#/$defs/envScopedGoogleGroups"
    },
    "platform_managed_project": {
      "description": "Platform-managed project configuration. Drives creation of GKE clusters and managed data services in pt-corpus.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cloud_sql": { "$ref": "#/$defs/cloudSQL" },
        "enable_datadog": {
          "description": "Enable Datadog integration for the platform-managed project.",
          "type": "boolean"
        },
        "kubernetes_engine": { "$ref": "#/$defs/kubernetesEngine" }
      }
    },
    "team_type": {
      "description": "Team Topologies type. Must match the team_key prefix.",
      "type": "string",
      "enum": [
        "platform-team",
        "stream-aligned-team",
        "complicated-subsystem-team",
        "enabling-team"
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "team_type": { "const": "platform-team" } }, "required": ["team_type"] },
      "then": { "properties": { "team_key": { "pattern": "^pt-" } } }
    },
    {
      "if": { "properties": { "team_type": { "const": "stream-aligned-team" } }, "required": ["team_type"] },
      "then": { "properties": { "team_key": { "pattern": "^st-" } } }
    },
    {
      "if": { "properties": { "team_type": { "const": "complicated-subsystem-team" } }, "required": ["team_type"] },
      "then": { "properties": { "team_key": { "pattern": "^ct-" } } }
    },
    {
      "if": { "properties": { "team_type": { "const": "enabling-team" } }, "required": ["team_type"] },
      "then": { "properties": { "team_key": { "pattern": "^et-" } } }
    }
  ],
  "$defs": {
    "emailList": {
      "type": "array",
      "items": { "type": "string", "format": "email", "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$" }
    },
    "usernameList": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$" }
    },
    "githubMembership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maintainers", "members"],
      "properties": {
        "maintainers": { "$ref": "#/$defs/usernameList" },
        "members": { "$ref": "#/$defs/usernameList" }
      }
    },
    "googleGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["managers", "members", "owners"],
      "properties": {
        "managers": { "$ref": "#/$defs/emailOrServiceAccountList" },
        "members": { "$ref": "#/$defs/emailOrServiceAccountList" },
        "owners": { "$ref": "#/$defs/emailOrServiceAccountList" }
      }
    },
    "emailOrServiceAccountList": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$" }
    },
    "envScopedGoogleGroups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sandbox", "non-production", "production"],
      "properties": {
        "sandbox": { "$ref": "#/$defs/googleGroup" },
        "non-production": { "$ref": "#/$defs/googleGroup" },
        "production": { "$ref": "#/$defs/googleGroup" }
      }
    },
    "githubRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "topics"],
      "properties": {
        "description": {
          "description": "Repository description shown on the homepage.",
          "type": "string"
        },
        "enable_datadog_secrets": { "type": "boolean" },
        "enable_datadog_webhook": { "type": "boolean" },
        "enable_google_wif_service_account": { "type": "boolean" },
        "enable_ruleset": { "type": "boolean" },
        "environments": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/githubEnvironment" }
        },
        "pages": { "$ref": "#/$defs/githubPages" },
        "topics": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
        }
      }
    },
    "githubEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "reviewers"],
      "properties": {
        "deployment_branch_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["custom_branch_policies", "protected_branches"],
          "properties": {
            "custom_branch_policies": { "type": "boolean" },
            "protected_branches": { "type": "boolean" }
          }
        },
        "name": { "type": "string" },
        "reviewers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["teams"],
          "properties": {
            "teams": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$" }
            }
          }
        }
      }
    },
    "githubPages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "build_type": { "type": "string", "enum": ["legacy", "workflow"] },
        "cname": { "type": "string" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["branch"],
          "properties": {
            "branch": { "type": "string" },
            "path": { "type": "string" }
          }
        }
      }
    },
    "cloudSQL": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regions"],
      "properties": {
        "database_version": { "type": "string" },
        "machine_tier": { "type": "string" },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["us-east1", "us-east4"] }
        }
      }
    },
    "kubernetesEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locations"],
      "properties": {
        "artifact_registry_groups_memberships": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readers", "writers"],
          "properties": {
            "readers": { "$ref": "#/$defs/googleGroup" },
            "writers": { "$ref": "#/$defs/googleGroup" }
          }
        },
        "dns_subdomain": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "enable_datadog_apm": { "type": "boolean" },
        "locations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/gkeLocation" }
        }
      }
    },
    "gkeLocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_pools", "subnet"],
      "properties": {
        "enable_gke_hub_host": { "type": "boolean" },
        "node_pools": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["machine_type", "max_node_count", "min_node_count"],
            "properties": {
              "machine_type": { "type": "string" },
              "max_node_count": { "type": "integer", "minimum": 0 },
              "min_node_count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "subnet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ip_cidr_range",
            "master_ipv4_cidr_block",
            "pod_ip_cidr_range",
            "services_ip_cidr_range"
          ],
          "properties": {
            "ip_cidr_range": { "type": "string", "format": "ipv4-cidr" },
            "master_ipv4_cidr_block": { "type": "string", "format": "ipv4-cidr" },
            "pod_ip_cidr_range": { "type": "string", "format": "ipv4-cidr" },
            "services_ip_cidr_range": { "type": "string", "format": "ipv4-cidr" }
          }
        }
      }
    }
  }
}
